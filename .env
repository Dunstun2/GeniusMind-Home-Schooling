# Server configuration
PORT=3000
SESSION_SECRET=genius_minds_secret_key_2026

# MySQL Database Configuration
# The server will automatically attempt to create the database genius_minds_db if it doesn't exist.
# If the connection fails, the server will gracefully fallback to an In-Memory database
# so you can test the entire app instantly without manual MySQL setup.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=GeniusAdmin2026!
DB_NAME=genius_minds_db

# Email Configuration (Nodemailer SMTP)
# To test emails, fill these out. Otherwise, emails are logged in development mode.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Genius Minds Homeschooling" <your_email@gmail.com>

# Target recipient for incoming booking requests
NOTIFICATION_RECIPIENT=geniusminds2425@gmail.com

# Default Admin Credentials (auto-seeded on first run)
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=GeniusAdmin2026!
