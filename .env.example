# Server configuration
PORT=3000
SESSION_SECRET=genius_minds_secret_key_2026

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=genius_minds_db

# Email Configuration (Nodemailer SMTP)
# For testing locally, you can use Mailtrap, Ethereal, or Gmail with an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Genius Minds Homeschooling" <your_email@gmail.com>

# Target recipient for incoming booking requests
NOTIFICATION_RECIPIENT=recipient_email@gmail.com

# Default Admin Credentials (auto-seeded on first run if DB is empty)
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=GeniusAdmin2026!
